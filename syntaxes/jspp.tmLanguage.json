{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "JSPP",
  "scopeName": "source.jspp",
  "patterns": [
    { "include": "#comments" },
    { "include": "#cpp-block" },
    { "include": "#imports" },
    { "include": "#strings" },
    { "include": "#template-strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#class-declaration" },
    { "include": "#function-declaration" },
    { "include": "#operators" },
    { "include": "#function-call" },
    { "include": "#identifiers" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.jspp",
          "begin": "//",
          "end": "$",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.jspp" }
          }
        },
        {
          "name": "comment.block.jspp",
          "begin": "/\\*",
          "end": "\\*/",
          "captures": {
            "0": { "name": "punctuation.definition.comment.jspp" }
          }
        }
      ]
    },
    "cpp-block": {
      "patterns": [
        {
          "name": "meta.embedded.block.cpp",
          "begin": "\\b(cpp)\\s*\\{",
          "end": "\\}",
          "beginCaptures": {
            "1": { "name": "keyword.control.cpp.jspp" }
          },
          "contentName": "source.cpp",
          "patterns": [
            { "include": "source.cpp" }
          ]
        },
        {
          "match": "\\b(cpp_include)\\b",
          "name": "keyword.control.import.jspp"
        }
      ]
    },
    "imports": {
      "patterns": [
        {
          "match": "\\b(import|export|from|as)\\b",
          "name": "keyword.control.import.jspp"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.jspp",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.jspp",
              "match": "\\\\(x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|.)"
            }
          ]
        },
        {
          "name": "string.quoted.single.jspp",
          "begin": "'",
          "end": "'",
          "patterns": [
            {
              "name": "constant.character.escape.jspp",
              "match": "\\\\(x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|.)"
            }
          ]
        }
      ]
    },
    "template-strings": {
      "name": "string.template.jspp",
      "begin": "`",
      "end": "`",
      "patterns": [
        {
          "name": "constant.character.escape.jspp",
          "match": "\\\\(x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|.)"
        },
        {
          "name": "meta.template.expression.jspp",
          "begin": "\\$\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.template-expression.begin.jspp" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.template-expression.end.jspp" }
          },
          "patterns": [
            { "include": "$self" }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.hex.jspp",
          "match": "\\b0x[0-9A-Fa-f]+\\b"
        },
        {
          "name": "constant.numeric.binary.jspp",
          "match": "\\b0b[01]+\\b"
        },
        {
          "name": "constant.numeric.float.jspp",
          "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.numeric.integer.jspp",
          "match": "\\b[0-9]+\\b"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.jspp",
          "match": "\\b(if|else|for|while|do|switch|case|default|break|continue|return|try|catch|throw|of)\\b"
        },
        {
          "name": "keyword.declaration.jspp",
          "match": "\\b(let|const|function|type|class|enum|constructor)\\b"
        },
        {
          "name": "keyword.other.jspp",
          "match": "\\b(new|shared_new|extends|super|this|operator|ref)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "support.type.primitive.jspp",
          "match": "\\b(int|i8|i16|i32|i64|u8|u16|u32|u64|float|double|bool|string|char|void|auto|size|ptr)\\b"
        },
        {
          "name": "support.type.annotation.jspp",
          "match": "(?<=:)\\s*([A-Z][A-Za-z0-9_]*)",
          "captures": {
            "1": { "name": "entity.name.type.jspp" }
          }
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.jspp",
          "match": "\\b(true|false|null)\\b"
        },
        {
          "name": "variable.language.this.jspp",
          "match": "\\b(this|super)\\b"
        },
        {
          "name": "constant.other.jspp",
          "match": "\\b[A-Z][A-Z0-9_]{2,}\\b"
        }
      ]
    },
    "class-declaration": {
      "match": "\\b(class|type|enum)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.jspp" },
        "2": { "name": "entity.name.type.class.jspp" }
      }
    },
    "function-declaration": {
      "match": "\\b(function)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "keyword.declaration.jspp" },
        "2": { "name": "entity.name.function.jspp" }
      }
    },
    "function-call": {
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.jspp" }
      }
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.arrow.jspp",
          "match": "=>"
        },
        {
          "name": "keyword.operator.comparison.jspp",
          "match": "===|!==|==|!=|<=|>=|<|>"
        },
        {
          "name": "keyword.operator.logical.jspp",
          "match": "&&|\\|\\||!"
        },
        {
          "name": "keyword.operator.assignment.jspp",
          "match": "\\+=|-=|\\*=|/=|%=|="
        },
        {
          "name": "keyword.operator.arithmetic.jspp",
          "match": "\\+\\+|--|\\+|-|\\*|/|%"
        },
        {
          "name": "keyword.operator.bitwise.jspp",
          "match": "&|\\||\\^|~|<<|>>"
        },
        {
          "name": "keyword.operator.other.jspp",
          "match": "::|\\?|:"
        }
      ]
    },
    "identifiers": {
      "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b",
      "name": "variable.other.jspp"
    },
    "punctuation": {
      "patterns": [
        {
          "name": "punctuation.terminator.jspp",
          "match": ";"
        },
        {
          "name": "punctuation.separator.jspp",
          "match": ","
        },
        {
          "name": "punctuation.accessor.jspp",
          "match": "\\."
        }
      ]
    }
  }
}
