{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "JSPP",
  "scopeName": "source.jspp",
  "fileTypes": ["jspp"],
  "patterns": [
    { "include": "#comments" },
    { "include": "#cpp-block" },
    { "include": "#cpp-include" },
    { "include": "#imports" },
    { "include": "#class-declaration" },
    { "include": "#type-declaration" },
    { "include": "#enum-declaration" },
    { "include": "#function-declaration" },
    { "include": "#constructor-declaration" },
    { "include": "#operator-declaration" },
    { "include": "#strings" },
    { "include": "#template-strings" },
    { "include": "#numbers" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#constants" },
    { "include": "#type-annotation" },
    { "include": "#operators" },
    { "include": "#function-call" },
    { "include": "#identifiers" },
    { "include": "#punctuation" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.jspp",
          "begin": "//",
          "end": "$",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.comment.jspp" }
          }
        },
        {
          "name": "comment.block.jspp",
          "begin": "/\\*",
          "end": "\\*/",
          "captures": {
            "0": { "name": "punctuation.definition.comment.jspp" }
          }
        }
      ]
    },
    "cpp-block": {
      "begin": "\\b(cpp)\\s*(\\{)",
      "end": "(\\})",
      "beginCaptures": {
        "1": { "name": "keyword.other.cpp.jspp" },
        "2": { "name": "punctuation.section.embedded.begin.jspp" }
      },
      "endCaptures": {
        "1": { "name": "punctuation.section.embedded.end.jspp" }
      },
      "contentName": "meta.embedded.block.cpp",
      "patterns": [
        { "include": "source.cpp" }
      ]
    },
    "cpp-include": {
      "match": "\\b(cpp_include)\\b\\s*(\"[^\"]*\"|<[^>]*>)?",
      "captures": {
        "1": { "name": "keyword.control.import.jspp" },
        "2": { "name": "string.quoted.other.include.jspp" }
      }
    },
    "imports": {
      "match": "\\b(import|export|from|as)\\b",
      "name": "keyword.control.import.jspp"
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.jspp",
          "begin": "\"",
          "end": "\"|$",
          "patterns": [
            {
              "name": "constant.character.escape.jspp",
              "match": "\\\\(x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|[nrtbf0\\\\'\"`])"
            }
          ]
        },
        {
          "name": "string.quoted.single.jspp",
          "begin": "'",
          "end": "'|$",
          "patterns": [
            {
              "name": "constant.character.escape.jspp",
              "match": "\\\\(x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|[nrtbf0\\\\'\"`])"
            }
          ]
        }
      ]
    },
    "template-strings": {
      "name": "string.template.jspp",
      "begin": "`",
      "end": "`",
      "patterns": [
        {
          "name": "constant.character.escape.jspp",
          "match": "\\\\(x[0-9A-Fa-f]{2}|u[0-9A-Fa-f]{4}|[nrtbf0\\\\'\"`])"
        },
        {
          "name": "meta.template.expression.jspp",
          "begin": "\\$\\{",
          "end": "\\}",
          "beginCaptures": {
            "0": { "name": "punctuation.definition.template-expression.begin.jspp" }
          },
          "endCaptures": {
            "0": { "name": "punctuation.definition.template-expression.end.jspp" }
          },
          "contentName": "meta.embedded.line.jspp",
          "patterns": [
            { "include": "$self" }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        { "name": "constant.numeric.hex.jspp", "match": "\\b0[xX][0-9A-Fa-f]+\\b" },
        { "name": "constant.numeric.binary.jspp", "match": "\\b0[bB][01]+\\b" },
        { "name": "constant.numeric.float.jspp", "match": "\\b[0-9]+\\.[0-9]+([eE][+-]?[0-9]+)?\\b" },
        { "name": "constant.numeric.integer.jspp", "match": "\\b[0-9]+\\b" }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.flow.jspp",
          "match": "\\b(if|else|for|while|do|switch|case|default|break|continue|return|try|catch|throw|of)\\b"
        },
        {
          "name": "storage.type.jspp",
          "match": "\\b(let|const|function|type|class|enum|constructor|operator)\\b"
        },
        {
          "name": "storage.modifier.jspp",
          "match": "\\b(ref|extends)\\b"
        },
        {
          "name": "keyword.operator.new.jspp",
          "match": "\\b(new|shared_new)\\b"
        }
      ]
    },
    "types": {
      "name": "support.type.primitive.jspp",
      "match": "\\b(int|i8|i16|i32|i64|u8|u16|u32|u64|float|double|bool|string|char|void|auto|size|ptr)\\b"
    },
    "type-annotation": {
      "match": "(:)\\s*([A-Z][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "punctuation.separator.type.jspp" },
        "2": { "name": "entity.name.type.jspp" }
      }
    },
    "constants": {
      "patterns": [
        { "name": "constant.language.boolean.jspp", "match": "\\b(true|false)\\b" },
        { "name": "constant.language.null.jspp", "match": "\\b(null)\\b" },
        { "name": "variable.language.this.jspp", "match": "\\b(this|super)\\b" },
        { "name": "constant.other.jspp", "match": "\\b[A-Z][A-Z0-9_]{2,}\\b" }
      ]
    },
    "class-declaration": {
      "match": "\\b(class)\\s+([A-Za-z_][A-Za-z0-9_]*)(?:\\s+(extends)\\s+([A-Za-z_][A-Za-z0-9_]*))?",
      "captures": {
        "1": { "name": "storage.type.class.jspp" },
        "2": { "name": "entity.name.type.class.jspp" },
        "3": { "name": "storage.modifier.jspp" },
        "4": { "name": "entity.other.inherited-class.jspp" }
      }
    },
    "type-declaration": {
      "match": "\\b(type)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "storage.type.jspp" },
        "2": { "name": "entity.name.type.jspp" }
      }
    },
    "enum-declaration": {
      "match": "\\b(enum)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "storage.type.enum.jspp" },
        "2": { "name": "entity.name.type.enum.jspp" }
      }
    },
    "function-declaration": {
      "match": "\\b(function)\\s+([A-Za-z_][A-Za-z0-9_]*)",
      "captures": {
        "1": { "name": "storage.type.function.jspp" },
        "2": { "name": "entity.name.function.jspp" }
      }
    },
    "constructor-declaration": {
      "match": "\\b(constructor)\\b(?=\\s*\\()",
      "captures": {
        "1": { "name": "storage.type.jspp" }
      }
    },
    "operator-declaration": {
      "match": "\\b(operator)\\s*(===|!==|<=|>=|<<|>>|[+\\-*/%<>])",
      "captures": {
        "1": { "name": "storage.type.jspp" },
        "2": { "name": "entity.name.function.operator.jspp" }
      }
    },
    "function-call": {
      "match": "\\b([A-Za-z_][A-Za-z0-9_]*)\\s*(?=\\()",
      "captures": {
        "1": { "name": "entity.name.function.call.jspp" }
      }
    },
    "operators": {
      "patterns": [
        { "name": "keyword.operator.arrow.jspp", "match": "=>" },
        { "name": "keyword.operator.comparison.jspp", "match": "===|!==|==|!=|<=|>=" },
        { "name": "keyword.operator.logical.jspp", "match": "&&|\\|\\||!(?!=)" },
        { "name": "keyword.operator.assignment.compound.jspp", "match": "\\+=|-=|\\*=|/=|%=" },
        { "name": "keyword.operator.assignment.jspp", "match": "=" },
        { "name": "keyword.operator.increment.jspp", "match": "\\+\\+|--" },
        { "name": "keyword.operator.arithmetic.jspp", "match": "[+\\-*/%]" },
        { "name": "keyword.operator.bitwise.jspp", "match": "<<|>>|&|\\||\\^|~" },
        { "name": "keyword.operator.relational.jspp", "match": "<|>" },
        { "name": "keyword.operator.scope.jspp", "match": "::" },
        { "name": "keyword.operator.ternary.jspp", "match": "\\?|:" }
      ]
    },
    "identifiers": {
      "match": "\\b[A-Za-z_][A-Za-z0-9_]*\\b",
      "name": "variable.other.jspp"
    },
    "punctuation": {
      "patterns": [
        { "name": "punctuation.terminator.statement.jspp", "match": ";" },
        { "name": "punctuation.separator.comma.jspp", "match": "," },
        { "name": "punctuation.accessor.jspp", "match": "\\." },
        { "name": "punctuation.section.brace.jspp", "match": "[{}]" },
        { "name": "punctuation.section.bracket.jspp", "match": "[\\[\\]]" },
        { "name": "punctuation.section.parens.jspp", "match": "[()]" }
      ]
    }
  }
}
